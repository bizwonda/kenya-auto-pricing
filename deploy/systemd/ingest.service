[Unit]
Description=Kenya Auto Pricing Data Pipeline
After=network.target

[Service]
Type=simple
User=carpricing
WorkingDirectory=/opt/kenya-auto-pricing
Environment=PATH=/opt/kenya-auto-pricing/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/opt/kenya-auto-pricing/venv/bin/python -m src.utils.ingest
Restart=always
RestartSec=30

[Install]
WantedBy=multi-user.target
